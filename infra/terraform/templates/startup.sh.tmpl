#!/usr/bin/env bash
set -euo pipefail

export DEBIAN_FRONTEND=noninteractive

apt-get update -y
apt-get install -y ca-certificates curl gnupg lsb-release git python3 rsync

fetch_secret_latest() {
  local project_id="$1"
  local secret_id="$2"

  local token_json
  token_json="$(curl -fsS -H "Metadata-Flavor: Google" "http://metadata.google.internal/computeMetadata/v1/instance/service-accounts/default/token")"
  local access_token
  access_token="$(printf '%s' "$${token_json}" | python3 -c 'import json,sys; print(json.load(sys.stdin)["access_token"])')"

  local secret_json
  secret_json="$(curl -fsS -H "Authorization: Bearer $${access_token}" "https://secretmanager.googleapis.com/v1/projects/$${project_id}/secrets/$${secret_id}/versions/latest:access")"
  printf '%s' "$${secret_json}" | python3 -c 'import json,sys,base64; print(base64.b64decode(json.load(sys.stdin)["payload"]["data"]).decode())'
}

install -m 0755 -d /etc/apt/keyrings
if [ ! -f /etc/apt/keyrings/docker.gpg ]; then
  curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
  chmod a+r /etc/apt/keyrings/docker.gpg
fi

ARCH="$(dpkg --print-architecture)"
RELEASE="$(. /etc/os-release && echo "$${VERSION_CODENAME}")"
echo "deb [arch=$${ARCH} signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $${RELEASE} stable" > /etc/apt/sources.list.d/docker.list

apt-get update -y
apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin

systemctl enable docker
systemctl start docker

if [ "${enable_caddy_https}" = "true" ] && [ "${enable_persistent_caddy_storage}" = "true" ] && [ -n "${caddy_data_disk_name}" ]; then
  CADDY_DISK_PATH="/dev/disk/by-id/google-${caddy_data_disk_name}"
  for _ in $(seq 1 30); do
    if [ -b "$${CADDY_DISK_PATH}" ]; then
      break
    fi
    sleep 1
  done

  if [ -b "$${CADDY_DISK_PATH}" ]; then
    if ! blkid "$${CADDY_DISK_PATH}" >/dev/null 2>&1; then
      mkfs.ext4 -F "$${CADDY_DISK_PATH}"
    fi

    install -d -m 0755 /var/lib/caddy
    CADDY_DISK_UUID="$(blkid -s UUID -o value "$${CADDY_DISK_PATH}")"
    if [ -n "$${CADDY_DISK_UUID}" ] && ! grep -q "$${CADDY_DISK_UUID}" /etc/fstab; then
      echo "UUID=$${CADDY_DISK_UUID} /var/lib/caddy ext4 defaults,nofail 0 2" >> /etc/fstab
    fi
    mountpoint -q /var/lib/caddy || mount /var/lib/caddy || true
  else
    echo "Persistent Caddy disk '$${CADDY_DISK_PATH}' not found; using boot disk storage."
  fi
fi

if [ "${enable_persistent_openclaw_storage}" = "true" ] && [ -n "${openclaw_data_disk_name}" ]; then
  OPENCLAW_DISK_PATH="/dev/disk/by-id/google-${openclaw_data_disk_name}"
  for _ in $(seq 1 30); do
    if [ -b "$${OPENCLAW_DISK_PATH}" ]; then
      break
    fi
    sleep 1
  done

  if [ -b "$${OPENCLAW_DISK_PATH}" ]; then
    if ! blkid "$${OPENCLAW_DISK_PATH}" >/dev/null 2>&1; then
      mkfs.ext4 -F "$${OPENCLAW_DISK_PATH}"
    fi

    install -d -m 0755 ${openclaw_data_mount_path}
    OPENCLAW_DISK_UUID="$(blkid -s UUID -o value "$${OPENCLAW_DISK_PATH}")"
    if [ -n "$${OPENCLAW_DISK_UUID}" ] && ! grep -q "$${OPENCLAW_DISK_UUID}" /etc/fstab; then
      echo "UUID=$${OPENCLAW_DISK_UUID} ${openclaw_data_mount_path} ext4 defaults,nofail 0 2" >> /etc/fstab
    fi
    mountpoint -q ${openclaw_data_mount_path} || mount ${openclaw_data_mount_path} || true
  else
    echo "Persistent OpenClaw disk '$${OPENCLAW_DISK_PATH}' not found; using boot disk for OPENCLAW_HOME."
  fi
fi

if [ "${enable_caddy_https}" = "true" ]; then
  if [ -n "${public_service_domain}" ]; then
    apt-get install -y caddy
    if [ "${enable_persistent_caddy_storage}" = "true" ] && mountpoint -q /var/lib/caddy; then
      chown -R caddy:caddy /var/lib/caddy
    fi

    CADDYFILE_TMP="$(mktemp)"
    cat >"$${CADDYFILE_TMP}" <<EOF_CADDY
${public_service_domain} {
  tls {
    issuer acme {
      dir ${caddy_acme_ca}
EOF_CADDY
    if [ -n "${caddy_acme_email}" ]; then
      cat >>"$${CADDYFILE_TMP}" <<EOF_CADDY
      email ${caddy_acme_email}
EOF_CADDY
    fi
    cat >>"$${CADDYFILE_TMP}" <<EOF_CADDY
    }
  }
  reverse_proxy 127.0.0.1:${service_port}
}
EOF_CADDY

    if [ -f /etc/caddy/Caddyfile ] && cmp -s "$${CADDYFILE_TMP}" /etc/caddy/Caddyfile; then
      echo "Caddyfile unchanged; skipping caddy reload."
      rm -f "$${CADDYFILE_TMP}"
      systemctl enable caddy
      if ! systemctl is-active --quiet caddy; then
        systemctl start caddy
      fi
    else
      install -m 0644 "$${CADDYFILE_TMP}" /etc/caddy/Caddyfile
      rm -f "$${CADDYFILE_TMP}"
      caddy validate --config /etc/caddy/Caddyfile
      systemctl enable caddy
      if systemctl is-active --quiet caddy; then
        systemctl reload caddy || systemctl restart caddy
      else
        systemctl start caddy
      fi
    fi
  else
    echo "Caddy HTTPS enabled but public_service_domain is empty; skipping Caddy config."
  fi
fi

if [ "${enable_tailscale}" = "true" ]; then
  curl -fsSL https://tailscale.com/install.sh | sh
  systemctl enable tailscaled
  systemctl start tailscaled

  TS_AUTH_KEY=""
  if [ -n "${tailscale_auth_key_secret_id}" ]; then
    TS_AUTH_KEY="$(fetch_secret_latest "${project_id}" "${tailscale_auth_key_secret_id}" || true)"
  fi

  TS_ARGS=(--hostname="${tailscale_hostname}")
  if [ "${tailscale_ssh}" = "true" ]; then
    TS_ARGS+=(--ssh)
  fi
  if [ "${tailscale_accept_routes}" = "true" ]; then
    TS_ARGS+=(--accept-routes)
  fi
  if [ -n "${tailscale_advertise_tags}" ]; then
    TS_ARGS+=(--advertise-tags="${tailscale_advertise_tags}")
  fi

  if [ -n "$${TS_AUTH_KEY}" ]; then
    if ! tailscale up --authkey="$${TS_AUTH_KEY}" "$${TS_ARGS[@]}"; then
      echo "Tailscale auth failed; continuing bootstrap without an active tailnet session."
    fi
  else
    echo "Tailscale enabled but auth key unavailable; run 'sudo tailscale up ...' manually."
  fi
fi

if [ "${write_telegram_env_file}" = "true" ] && [ -n "${telegram_bot_token_secret_id}" ]; then
  TG_BOT_TOKEN="$(fetch_secret_latest "${project_id}" "${telegram_bot_token_secret_id}" || true)"
  if [ -n "$${TG_BOT_TOKEN}" ]; then
    TELEGRAM_ENV_DIR="$(dirname "${telegram_env_file_path}")"
    install -d -m 0750 "$${TELEGRAM_ENV_DIR}"
    umask 177
    cat >"${telegram_env_file_path}" <<EOF_TG
TELEGRAM_BOT_TOKEN=$${TG_BOT_TOKEN}
EOF_TG
    chmod 0600 "${telegram_env_file_path}"
  else
    echo "Telegram secret '${telegram_bot_token_secret_id}' unavailable; skipping telegram env file."
  fi
fi

if [ "${write_inference_env_file}" = "true" ] && [ -n "${anthropic_api_key_secret_id}" ]; then
  ANTHROPIC_API_KEY_VALUE="$(fetch_secret_latest "${project_id}" "${anthropic_api_key_secret_id}" || true)"
  if [ -n "$${ANTHROPIC_API_KEY_VALUE}" ]; then
    INFERENCE_ENV_DIR="$(dirname "${inference_env_file_path}")"
    install -d -m 0750 "$${INFERENCE_ENV_DIR}"
    umask 177
    cat >"${inference_env_file_path}" <<EOF_INF
ANTHROPIC_API_KEY=$${ANTHROPIC_API_KEY_VALUE}
OPENCLAW_PRIMARY_MODEL=${openclaw_primary_model}
EOF_INF
    chmod 0600 "${inference_env_file_path}"
  else
    echo "Anthropic secret '${anthropic_api_key_secret_id}' unavailable; skipping inference env file."
  fi
fi

if [ "${write_openclaw_gateway_env_file}" = "true" ]; then
  OPENCLAW_GATEWAY_TOKEN_VALUE=""
  if [ -n "${openclaw_gateway_token_secret_id}" ]; then
    OPENCLAW_GATEWAY_TOKEN_VALUE="$(fetch_secret_latest "${project_id}" "${openclaw_gateway_token_secret_id}" || true)"
  fi

  OPENCLAW_GATEWAY_ENV_DIR="$(dirname "${openclaw_gateway_env_file_path}")"
  install -d -m 0750 "$${OPENCLAW_GATEWAY_ENV_DIR}"

  if [ -z "$${OPENCLAW_GATEWAY_TOKEN_VALUE}" ] && [ -f "${openclaw_gateway_env_file_path}" ]; then
    OPENCLAW_GATEWAY_TOKEN_VALUE="$(grep '^OPENCLAW_GATEWAY_TOKEN=' "${openclaw_gateway_env_file_path}" | head -n1 | cut -d= -f2- || true)"
  fi

  if [ -z "$${OPENCLAW_GATEWAY_TOKEN_VALUE}" ]; then
    OPENCLAW_GATEWAY_TOKEN_VALUE="$(python3 - <<'PY'
import secrets
print(secrets.token_urlsafe(48))
PY
)"
  fi

  umask 177
  cat >"${openclaw_gateway_env_file_path}" <<EOF_OG
OPENCLAW_GATEWAY_TOKEN=$${OPENCLAW_GATEWAY_TOKEN_VALUE}
GOG_KEYRING_PASSWORD=$${OPENCLAW_GATEWAY_TOKEN_VALUE}
OPENCLAW_GATEWAY_BIND=${openclaw_gateway_bind}
OPENCLAW_GATEWAY_PORT=${service_port}
EOF_OG
  chmod 0600 "${openclaw_gateway_env_file_path}"
fi

if [ "${write_github_env_file}" = "true" ]; then
  GITHUB_ENV_DIR="$(dirname "${github_env_file_path}")"
  install -d -m 0750 "$${GITHUB_ENV_DIR}"
  : >"${github_env_file_path}"
  chmod 0600 "${github_env_file_path}"
  WROTE_GITHUB_AUTH="false"

  if [ -n "${github_pat_secret_id}" ]; then
    GITHUB_PAT_VALUE="$(fetch_secret_latest "${project_id}" "${github_pat_secret_id}" || true)"
    if [ -n "$${GITHUB_PAT_VALUE}" ]; then
      cat >>"${github_env_file_path}" <<EOF_GH_PAT
GITHUB_PAT=$${GITHUB_PAT_VALUE}
GH_TOKEN=$${GITHUB_PAT_VALUE}
GITHUB_TOKEN=$${GITHUB_PAT_VALUE}
EOF_GH_PAT
      chmod 0600 "${github_env_file_path}"
      WROTE_GITHUB_AUTH="true"
    else
      echo "GitHub PAT secret '${github_pat_secret_id}' unavailable; skipping PAT auth."
    fi
  fi

  if [ -n "${github_app_id}" ] && [ -n "${github_app_installation_id}" ]; then
    GITHUB_APP_PRIVATE_KEY_VALUE=""
    if [ -n "${github_app_private_key_secret_id}" ]; then
      GITHUB_APP_PRIVATE_KEY_VALUE="$(fetch_secret_latest "${project_id}" "${github_app_private_key_secret_id}" || true)"
    fi

    if [ -n "$${GITHUB_APP_PRIVATE_KEY_VALUE}" ]; then
      GITHUB_KEY_DIR="$(dirname "${github_app_private_key_path}")"
      install -d -m 0750 "$${GITHUB_KEY_DIR}"

      umask 177
      cat >"${github_app_private_key_path}" <<EOF_GH_KEY
$${GITHUB_APP_PRIVATE_KEY_VALUE}
EOF_GH_KEY
      chmod 0600 "${github_app_private_key_path}"

      cat >>"${github_env_file_path}" <<EOF_GH_ENV
GITHUB_APP_ID=${github_app_id}
GITHUB_INSTALLATION_ID=${github_app_installation_id}
GITHUB_APP_PRIVATE_KEY_PATH=${github_app_private_key_path}
EOF_GH_ENV
      chmod 0600 "${github_env_file_path}"
      WROTE_GITHUB_AUTH="true"
    else
      echo "GitHub App private key secret '${github_app_private_key_secret_id}' unavailable; skipping App auth."
    fi
  fi

  if [ "$${WROTE_GITHUB_AUTH}" != "true" ]; then
    echo "No GitHub auth materialized; gh will be unauthenticated."
  fi
fi

if [ "${write_claude_code_env_file}" = "true" ] && [ -n "${claude_code_anthropic_api_key_secret_id}" ]; then
  CLAUDE_CODE_API_KEY_VALUE="$(fetch_secret_latest "${project_id}" "${claude_code_anthropic_api_key_secret_id}" || true)"
  if [ -n "$${CLAUDE_CODE_API_KEY_VALUE}" ]; then
    CLAUDE_CODE_ENV_DIR="$(dirname "${claude_code_env_file_path}")"
    install -d -m 0750 "$${CLAUDE_CODE_ENV_DIR}"
    umask 177
    cat >"${claude_code_env_file_path}" <<EOF_CC
ANTHROPIC_API_KEY=$${CLAUDE_CODE_API_KEY_VALUE}
ANTHROPIC_MODEL=${claude_code_model}
CLAUDE_CODE_MODEL=${claude_code_model}
CLAUDE_CODE_SUBAGENT_MODEL=${claude_code_subagent_model}
EOF_CC
    chmod 0600 "${claude_code_env_file_path}"
  else
    echo "Claude Code secret '${claude_code_anthropic_api_key_secret_id}' unavailable; skipping Claude Code env file."
  fi
fi

mkdir -p /opt/althea

cat >/etc/systemd/system/althea-stack.service <<UNIT
[Unit]
Description=Althea Docker Compose Stack
Requires=docker.service
After=docker.service network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=${bootstrap_repo_dir}
ExecStart=/usr/bin/docker compose -f ${bootstrap_compose_file} up -d
ExecStop=/usr/bin/docker compose -f ${bootstrap_compose_file} down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
UNIT

if [ -n "${bootstrap_repo_url}" ]; then
  mkdir -p "$(dirname "${bootstrap_repo_dir}")"

  if [ ! -d "${bootstrap_repo_dir}/.git" ]; then
    git clone "${bootstrap_repo_url}" "${bootstrap_repo_dir}"
  fi

  cd "${bootstrap_repo_dir}"
  git fetch --all --tags
  git checkout "${bootstrap_repo_ref}"
  git pull --ff-only origin "${bootstrap_repo_ref}" || true

  # When set in Terraform, skip Telegram pairing on every boot (git pull resets repo defaults).
  export OC_TG_ALLOW_FROM='${openclaw_telegram_allow_from_user_ids}'
  python3 <<'PY'
import json
import os
import sys
from pathlib import Path

raw = os.environ.get("OC_TG_ALLOW_FROM", "[]")
try:
    allow_from = json.loads(raw)
except json.JSONDecodeError as e:
    print("Invalid OC_TG_ALLOW_FROM JSON:", e, file=sys.stderr)
    sys.exit(1)

if not allow_from:
    sys.exit(0)

path = Path("openclaw/openclaw.json")
if not path.is_file():
    print("OpenClaw config not found:", path.resolve(), file=sys.stderr)
    sys.exit(1)

data = json.loads(path.read_text())
tg = data.setdefault("channels", {}).setdefault("telegram", {})
tg["dmPolicy"] = "allowlist"
tg["allowFrom"] = allow_from
path.write_text(json.dumps(data, indent=2) + "\n")
print("OpenClaw Telegram: dmPolicy=allowlist, allowFrom=", allow_from)
PY

  if [ ! -f ".env" ] && [ -f ".env.example" ]; then
    cp .env.example .env
    chmod 0600 .env
  fi

  if [ "${enable_persistent_openclaw_storage}" = "true" ] && mountpoint -q ${openclaw_data_mount_path}; then
    install -d -m 0755 ${openclaw_data_mount_path}/home ${openclaw_data_mount_path}/backups
    REPO_HOME="${bootstrap_repo_dir}/openclaw/home"
    if [ -d "$${REPO_HOME}" ] && [ -n "$(ls -A "$${REPO_HOME}" 2>/dev/null || true)" ] && [ -z "$(ls -A ${openclaw_data_mount_path}/home 2>/dev/null || true)" ]; then
      echo "Migrating OpenClaw home from repo to persistent disk..."
      rsync -a "$${REPO_HOME}/" ${openclaw_data_mount_path}/home/
    fi
    ENV_FILE="${bootstrap_repo_dir}/.env"
    if [ -f "$${ENV_FILE}" ]; then
      if grep -q '^OPENCLAW_HOME_DIR=' "$${ENV_FILE}"; then
        sed -i "s|^OPENCLAW_HOME_DIR=.*|OPENCLAW_HOME_DIR=${openclaw_data_mount_path}/home|" "$${ENV_FILE}"
      else
        printf '\nOPENCLAW_HOME_DIR=%s/home\n' "${openclaw_data_mount_path}" >> "$${ENV_FILE}"
      fi
    fi
  fi

  if [ -f "${bootstrap_compose_file}" ]; then
    systemctl daemon-reload
    systemctl enable althea-stack.service
    systemctl start althea-stack.service
  fi

  if [ "${enable_openclaw_home_backup_timer}" = "true" ] && [ "${enable_persistent_openclaw_storage}" = "true" ] && mountpoint -q ${openclaw_data_mount_path} && [ -x "${bootstrap_repo_dir}/scripts/backup-openclaw-home.sh" ]; then
    install -m 0755 "${bootstrap_repo_dir}/scripts/backup-openclaw-home.sh" /usr/local/sbin/althea-backup-openclaw-home.sh
    cat >/etc/systemd/system/althea-openclaw-home-backup.service <<EOF_OC_BAK
[Unit]
Description=Backup OpenClaw home directory

[Service]
Type=oneshot
Environment=ALTHEA_APP_ROOT=${bootstrap_repo_dir}
Environment=OPENCLAW_BACKUP_ROOT=${openclaw_data_mount_path}/backups
ExecStart=/usr/local/sbin/althea-backup-openclaw-home.sh
EOF_OC_BAK
    cat >/etc/systemd/system/althea-openclaw-home-backup.timer <<'EOF_OC_TMR'
[Unit]
Description=Daily backup of OpenClaw home

[Timer]
OnCalendar=daily
Persistent=true

[Install]
WantedBy=timers.target
EOF_OC_TMR
    systemctl daemon-reload
    systemctl enable althea-openclaw-home-backup.timer
    systemctl start althea-openclaw-home-backup.timer || true
  fi
fi
