OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BIND_HOST=127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1
ENFORCE_HTTPS_HEADERS=false

# Runtime env files materialized by Terraform startup.
OPENCLAW_GATEWAY_ENV_FILE=/opt/althea/runtime/openclaw.env
GITHUB_ENV_FILE=/opt/althea/runtime/github.env
TELEGRAM_ENV_FILE=/opt/althea/runtime/telegram.env
INFERENCE_ENV_FILE=/opt/althea/runtime/inference.env
CLAUDE_CODE_ENV_FILE=/opt/althea/runtime/claude-code.env

# Persist OpenClaw runtime state (sessions/history/memory/workspace) outside container FS.
# Local/dev: relative to compose working directory.
OPENCLAW_HOME_DIR=./openclaw/home
# GCP VM with Terraform persistent disk (see infra/terraform): startup rewrites this to e.g.
# OPENCLAW_HOME_DIR=/mnt/openclaw-data/home
